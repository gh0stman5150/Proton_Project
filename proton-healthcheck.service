[Unit]
Description=Proton Throughput Healthcheck
After=proton-wg.service proton-port-forward.service
Requires=proton-wg.service proton-port-forward.service
PartOf=proton-wg.service

[Service]
Type=simple
EnvironmentFile=-/etc/proton/proton-common.env
EnvironmentFile=-/etc/proton/proton-healthcheck.env
ExecStart=/usr/local/bin/proton/proton-healthcheck.sh
Restart=always
RestartSec=10
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ProtectHome=yes

[Install]
WantedBy=multi-user.target