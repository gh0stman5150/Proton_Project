+		while read -r handle; do
+			[[ -n "$handle" ]] || continue
+			nft delete rule ip proton_nat postrouting handle "$handle" 2>/dev/null || true
+		done <<< "$handles"
+	fi
+
+	nft add rule ip proton_nat postrouting oifname "$VPN_IF" masquerade comment "proton-wg-snat"
+}
