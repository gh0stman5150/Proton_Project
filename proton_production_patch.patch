+
+ensure_masquerade_rule() {
+	local handles
+
+	handles="$(nft list chain ip proton_nat postrouting -a 2>/dev/null | awk -v vpn_if="$VPN_IF" '''$0 ~ "oifname \\"" vpn_if "\\"" && $0 ~ / masquerade/ {for(i=1;i<=NF;i++) if($i=="handle") print $(i+1)}''')"
